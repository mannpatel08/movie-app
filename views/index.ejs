<%- include('header') %>

<div class="header-section">
    <h1>Browse Movies</h1>
    <% if (movies.length === 0) { %>
        <div style="text-align: center; margin-top: 50px;">
            <p style="color: #b3b3b3; font-size: 1.2rem;">No movies found. Start by adding some!</p>
            <a href="/add" class="btn-submit" style="display: inline-block; width: auto; margin-top: 20px; text-decoration: none;">Add Your First Movie</a>
        </div>
    <% } %>
</div>

<div class="movie-grid">
    <% movies.forEach(movie => { %>
        <div class="movie-card">
            <img src="/assets/uploads/<%= movie.image %>" alt="<%= movie.title %>">
            <div class="movie-info">
                <h3><%= movie.title %></h3>
                <div class="meta">
                    <span><%= movie.genre %></span>
                    <span><i class="fa-solid fa-star" style="color: gold;"></i> <%= movie.rating %></span>
                    <span><%= movie.releaseYear %></span>
                </div>
                <p style="font-size: 0.8rem; color: #888; margin-top: 10px; height: 35px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                    <%= movie.description %>
                </p>
            </div>
            <div class="movie-actions">
                <a href="/edit/<%= movie._id %>" class="btn-icon" title="Edit">
                    <i class="fa-solid fa-pen-to-square"></i>
                </a>
                <a href="/delete/<%= movie._id %>" class="btn-icon" title="Delete" onclick="return confirm('Are you sure you want to delete this movie?')">
                    <i class="fa-solid fa-trash"></i>
                </a>
            </div>
        </div>
    <% }) %>
</div>

<%- include('footer') %>
