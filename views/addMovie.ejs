<%- include('header') %>

<div class="form-container">
    <h2>Add New Movie</h2>
    <form action="/add" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Movie Title</label>
            <input type="text" id="title" name="title" placeholder="Enter movie title" required>
        </div>
        
        <div class="form-group">
            <label for="genre">Genre</label>
            <select id="genre" name="genre" required>
                <option value="" disabled selected>Select genre</option>
                <option value="Action">Action</option>
                <option value="Comedy">Comedy</option>
                <option value="Drama">Drama</option>
                <option value="Horror">Horror</option>
                <option value="Sci-Fi">Sci-Fi</option>
                <option value="Romance">Romance</option>
                <option value="Thriller">Thriller</option>
                <option value="Animation">Animation</option>
            </select>
        </div>

        <div style="display: flex; gap: 20px;">
            <div class="form-group" style="flex: 1;">
                <label for="rating">Rating (0-10)</label>
                <input type="number" id="rating" name="rating" min="0" max="10" step="0.1" placeholder="8.5">
            </div>
            <div class="form-group" style="flex: 1;">
                <label for="releaseYear">Release Year</label>
                <input type="number" id="releaseYear" name="releaseYear" min="1900" max="2026" placeholder="2024">
            </div>
        </div>

        <div class="form-group">
            <label for="image">Movie Poster</label>
            <input type="file" id="image" name="image" accept="image/*" required>
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4" placeholder="Enter movie description..." required></textarea>
        </div>

        <button type="submit" class="btn-submit">Upload Movie</button>
    </form>
</div>

<%- include('footer') %>
